# ─── EtHOS environment variables ─────────────────────────────────────────────
# Copy this file to `.env.local` for local dev, and add the same variables
# in your Vercel project: Settings → Environment Variables.

# Postgres connection string from Neon (https://neon.tech)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# NextAuth secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Public URL of your site. Use http://localhost:3000 locally.
NEXTAUTH_URL=http://localhost:3000

# Initial super-admin credentials, used by `pnpm db:seed` on first run.
# After the first seed you can rotate the password from the super-admin UI.
SEED_SUPER_ADMIN_EMAIL=you@example.com
SEED_SUPER_ADMIN_PASSWORD=change-me-immediately
